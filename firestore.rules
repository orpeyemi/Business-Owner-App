rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Validation functions
    function isValidPost(data) {
      return data.uid == request.auth.uid &&
             data.content is string && data.content.size() > 0 &&
             data.platform is string &&
             data.createdAt is string;
    }

    function isValidReminder(data) {
      return data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 &&
             data.scheduledTime is string &&
             data.status in ['pending', 'completed'];
    }

    function isValidNote(data) {
      return data.uid == request.auth.uid &&
             data.title is string && data.title.size() > 0 &&
             data.content is string &&
             data.updatedAt is string;
    }

    match /posts/{postId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isDocOwner() && isValidPost(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /reminders/{reminderId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidReminder(request.resource.data);
      allow update: if isDocOwner() && isValidReminder(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isDocOwner() && isValidNote(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
